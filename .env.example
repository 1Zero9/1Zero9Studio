# Public site URL (used for canonical URLs, sitemap, feeds; override on previews)
NEXT_PUBLIC_SITE_URL=https://1zero9.com

# --- Admin portal (private, single-user) ---

# Signs/verifies session + magic-link tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# The sole allowlisted admin login email.
ADMIN_EMAIL=

# Postgres connection string for Prisma (Vercel Marketplace Postgres, e.g. Neon).
DATABASE_URL=
# Only needed if the provider gives a separate non-pooled connection for
# migrations (e.g. Neon) — see prisma.config.ts.
# DIRECT_URL=

# Sends magic-link emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Vercel Blob (Storage tab on the Vercel project; auto-injected once linked).
BLOB_READ_WRITE_TOKEN=
