# Supabase Configuration
# Get these values from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Supabase Auth is required for holiday concierge accounts.
# Run SQL in supabase/holiday_agent_schema.sql to create concierge tables.

# Resend Email Configuration
# Get these from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_ADMIN_EMAIL=your-email@example.com
# Optional: enables queued concierge completion emails
# CONSULTATION ready notifications will still appear in-app without this.

# Google Gemini API Configuration
# Get your API key from https://aistudio.google.com/app/apikey
# Free tier: 15 requests/minute, 1 million tokens/day
GEMINI_API_KEY=your-gemini-api-key-here

# Travel API Configuration (optional for holiday-agent route)
# If omitted, the app falls back to intelligent estimates.
# Amadeus for flights: https://developers.amadeus.com/
# Also used for hotel offers to build live dynamic packages
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret
# Optional: defaults to test endpoint
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Hotel and package source via RapidAPI (e.g., Booking-com APIs)
# https://rapidapi.com/
BOOKING_RAPIDAPI_KEY=your-rapidapi-key

# Concierge background worker secret (optional but recommended)
# Use this in scheduled calls to /api/holiday/concierge/jobs/process
CONCIERGE_CRON_SECRET=your-random-secret

# Admin access for /holiday-agent/admin
# Comma-separated allow-list fallback, e.g. admin@yourdomain.com,owner@yourdomain.com
HOLIDAY_ADMIN_EMAILS=admin@example.com

# Media Guide Neon database
# Used by /media-guide and /api/media-guide/watchlist
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
MEDIA_GUIDE_PASSWORD=choose-a-private-password
MEDIA_GUIDE_SESSION_SECRET=choose-a-long-random-secret

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual credentials
# 3. For Resend: Use 'onboarding@resend.dev' for testing, your domain in production
# 4. For Gemini API: Sign up at https://aistudio.google.com/app/apikey to get your FREE API key
# 5. Never commit .env.local to git
