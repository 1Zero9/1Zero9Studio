generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProjectMedia {
  id          String   @id @default(cuid())
  projectSlug String
  url         String
  alt         String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([projectSlug])
}

model ProjectLink {
  id          String   @id @default(cuid())
  projectSlug String
  label       String
  url         String
  kind        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([projectSlug])
}

model ProjectOutcome {
  id          String   @id @default(cuid())
  projectSlug String
  text        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([projectSlug])
}

model Testimonial {
  id          String   @id @default(cuid())
  quote       String
  author      String
  role        String?
  projectSlug String?
  published   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SiteCopy {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AdminLoginToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
}
